function showView(view, navEl){
  document.querySelectorAll('.adm-view').forEach(v=>v.classList.remove('active'));
  const el = document.getElementById('view-'+view);
  if(el) el.classList.add('active');
  if(navEl){ document.querySelectorAll('.adm-nav-item').forEach(n=>n.classList.remove('active')); navEl.classList.add('active'); }
