function toggleChat(){
  chatOpen = !chatOpen;
  const win = document.getElementById('chatWin');
  win.classList.toggle('open', chatOpen);
  if(chatOpen && document.getElementById('chatMsgs').children.length===0) initChat();
}
function initChat(){
  document.getElementById('chatMsgs').innerHTML='';
  document.getElementById('chatOpts').innerHTML='';
  addBotMsg(chatFlow.start.msg);
  setTimeout(()=>showChatOpts(chatFlow.start.opts), 500);
}
function addBotMsg(txt){
  const el = document.createElement('div');
  el.className='msg bot';
  el.innerHTML=`<div class="msg-bubble">${txt.replace(/\*(.+?)\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}</div>`;
  document.getElementById('chatMsgs').appendChild(el);
  document.getElementById('chatMsgs').scrollTop=9999;
}
function addUserMsg(txt){
  const el = document.createElement('div');
  el.className='msg user';
  el.innerHTML=`<div class="msg-bubble">${txt}</div>`;
  document.getElementById('chatMsgs').appendChild(el);
  document.getElementById('chatMsgs').scrollTop=9999;
}
function showChatOpts(opts){
  const c=document.getElementById('chatOpts');
  c.innerHTML=opts.map(o=>`<button class="chat-opt-btn" onclick="chatPick('${o.v}','${o.l}')">${o.l}</button>`).join('');
}
function chatPick(val,label){
  addUserMsg(label);
  document.getElementById('chatOpts').innerHTML='';
  if(val==='wa'){ setTimeout(()=>{ openWA('Property enquiry via RealtorBot'); addBotMsg('✅ WhatsApp is opening! Broker Rajesh will help you right away.'); }, 600); return; }
  if(val==='form'){ setTimeout(()=>{ openOverlay('contactOverlay'); addBotMsg('📋 Opening the enquiry form for you!'); }, 600); return; }
  const flow = chatFlow[val] || chatFlow.connect;
  if(flow){ setTimeout(()=>{ addBotMsg(flow.msg); if(flow.opts) setTimeout(()=>showChatOpts(flow.opts),400); }, 600); }
}
function sendChat(){
  const inp=document.getElementById('chatInp');
  const txt=inp.value.trim();
  if(!txt) return;
  addUserMsg(txt);
  inp.value='';
  document.getElementById('chatOpts').innerHTML='';
  setTimeout(()=>{ addBotMsg("I'd love to help you find the right property! Let me connect you with our expert broker."); setTimeout(()=>showChatOpts([{l:'💬 WhatsApp Broker',v:'wa'},{l:'📋 Fill Form',v:'form'}]),400); }, 700);
}

