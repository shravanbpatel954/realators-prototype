.act-wa{background:rgba(37,211,102,.1);color:var(--wa)}
.act-wa:hover{background:var(--wa);color:#fff}
.act-view{background:rgba(201,168,76,.1);color:var(--gold)}
.act-view:hover{background:var(--gold);color:#fff}

