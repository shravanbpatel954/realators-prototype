.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-bottom:24px}
.stat-card{background:#fff;border-radius:var(--r-md);padding:22px;box-shadow:var(--shadow-sm);border:1px solid var(--border2);display:flex;align-items:center;gap:16px;transition:all .25s}
.stat-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
.stat-icon-wrap{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0}
.si-navy{background:rgba(13,27,42,.08)}
.si-gold{background:rgba(201,168,76,.12)}
.si-green{background:rgba(46,204,113,.1)}
.si-purple{background:rgba(142,68,173,.1)}
.stat-info-val{font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:700;color:var(--navy);line-height:1}
.stat-info-lbl{font-size:.78rem;color:var(--text3);margin-top:2px}
.stat-info-change{font-size:.74rem;font-weight:700;margin-top:5px}
.up{color:#1a7a44}
.dn{color:#c0392b}

/* Admin cards */
.adm-card{background:#fff;border-radius:var(--r-md);padding:22px;box-shadow:var(--shadow-sm);border:1px solid var(--border2)}
.adm-card h3{font-family:'Plus Jakarta Sans',sans-serif;font-size:.95rem;font-weight:700;color:var(--navy);margin-bottom:18px;display:flex;justify-content:space-between;align-items:center}
.adm-card h3 a{font-size:.78rem;color:var(--gold);font-weight:600;cursor:pointer}

/* Dashboard grid */
.dash-grid{display:grid;grid-template-columns:1.6fr 1fr;gap:20px;margin-bottom:20px}

