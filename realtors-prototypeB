// LOGIN
// ═══════════════════════════════════════
const CREDS = { admin:'admin123', broker:'broker2025' };
function doLogin(){
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value.trim();
  const err = document.getElementById('loginError');
  const msgEl = document.getElementById('loginErrorMsg');
  if(!u||!p){ err.classList.add('show'); msgEl.textContent='Please enter username and password.'; return; }
  if(CREDS[u]===p){ err.classList.remove('show'); switchTo('admin'); buildChart(); toast('✅ Welcome back, Rajesh!'); }
  else { err.classList.add('show'); msgEl.textContent='Invalid credentials. Please try again.'; document.getElementById('loginPass').value=''; }
}
document.addEventListener('keydown',e=>{ if(e.key==='Enter'&&document.getElementById('loginPanel').classList.contains('active')) doLogin(); });
function togglePass(){
  const inp = document.getElementById('loginPassInput') || document.getElementById('loginPass');
  if(inp) inp.type = inp.type==='password'?'text':'password';
}
function doLogout(){ switchTo('login'); toast('👋 Logged out successfully'); }

