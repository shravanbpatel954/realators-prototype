.form-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.form-field{display:flex;flex-direction:column;gap:6px}
.form-field label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text3)}
.form-field input,.form-field select,.form-field textarea{border:1.5px solid var(--border2);border-radius:var(--r-sm);padding:11px 14px;font-size:.88rem;font-family:inherit;color:var(--text);background:#fff;outline:none;transition:all .2s}
.form-field input:focus,.form-field select:focus,.form-field textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,.1)}
.form-field textarea{resize:vertical;min-height:90px}
.amenity-grid{display:flex;flex-wrap:wrap;gap:10px}
.am-check{display:flex;align-items:center;gap:7px;font-size:.84rem;cursor:pointer;color:var(--text2)}
.am-check input{accent-color:var(--navy);width:15px;height:15px}
.drop-zone{border:2px dashed var(--border2);border-radius:var(--r-md);padding:36px;text-align:center;cursor:pointer;transition:all .25s;color:var(--text3)}
.drop-zone:hover{border-color:var(--gold);background:rgba(201,168,76,.03);color:var(--gold)}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border2)}
.toggle-row:last-child{border-bottom:none}
.toggle-info h5{font-size:.88rem;font-weight:600;color:var(--text)}
.toggle-info p{font-size:.77rem;color:var(--text3);margin-top:2px}
.tgl{position:relative;width:42px;height:24px;flex-shrink:0}
.tgl input{display:none}
.tgl-track{width:42px;height:24px;border-radius:12px;background:#D1D5DB;cursor:pointer;transition:background .2s;position:relative;display:block}
.tgl-thumb{position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,.25)}
.tgl input:checked + .tgl-track{background:var(--green)}
.tgl input:checked + .tgl-track .tgl-thumb{transform:translateX(18px)}
.form-actions{display:flex;gap:12px;flex-wrap:wrap}

/* Leads & messages */
.lead-tag{display:inline-flex;align-items:center;gap:5px;font-size:.74rem;font-weight:600}
.lead-src{font-size:.78rem;font-weight:600;color:var(--text3);display:flex;align-items:center;gap:4px}

/* WhatsApp log cards */
.wa-log-card{border:1.5px solid var(--border2);border-radius:var(--r-md);padding:18px;display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:12px;transition:all .25s}
.wa-log-card:hover{border-color:rgba(201,168,76,.3);box-shadow:var(--shadow-sm)}
.wa-log-name{font-weight:700;font-size:.9rem;color:var(--text)}
.wa-log-msg{font-size:.82rem;color:var(--text3);margin-top:3px}
.wa-log-time{font-size:.72rem;color:var(--text3);margin-top:5px}
.wa-log-actions{display:flex;gap:8px;flex-shrink:0}

/* Settings */
.settings-section{background:#fff;border-radius:var(--r-md);padding:24px;margin-bottom:18px;border:1px solid var(--border2)}
.settings-section h4{font-size:.9rem;font-weight:700;color:var(--navy);margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border2)}

/* Admin views */
.adm-view{display:none}
.adm-view.active{display:block}

/* ════════════════════════════════════════════
   TOAST
════════════════════════════════════════════ */
.toast-wrap{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:8px;align-items:center;pointer-events:none}
.toast{background:var(--navy);color:#fff;padding:12px 22px;border-radius:24px;font-size:.84rem;font-weight:600;opacity:0;transform:translateY(10px) scale(.95);transition:all .3s cubic-bezier(.4,0,.2,1);white-space:nowrap;border:1px solid rgba(201,168,76,.25);box-shadow:var(--shadow-md)}
.toast.show{opacity:1;transform:translateY(0) scale(1)}

