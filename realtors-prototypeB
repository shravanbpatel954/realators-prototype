.act-item{display:flex;gap:12px;align-items:flex-start}
.act-dot{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.act-content{flex:1}
.act-title{font-size:.85rem;font-weight:600;color:var(--text)}
.act-time{font-size:.75rem;color:var(--text3);margin-top:2px}

/* Add property form */
.form-section{background:#fff;border-radius:var(--r-md);padding:24px;margin-bottom:18px;border:1px solid var(--border2)}
.form-section h4{font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;font-weight:700;color:var(--navy);margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border2);display:flex;align-items:center;gap:8px}
