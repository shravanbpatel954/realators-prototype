// ═══════════════════════════════════════
// CHART
// ═══════════════════════════════════════
function buildChart(){
  const area = document.getElementById('chartArea');
  if(!area) return;
  const months=['Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar'];
  const leads=[18,24,22,30,28,35,40,38,42];
  const closed=[3,4,5,6,5,7,8,7,9];
  const max=Math.max(...leads);
  area.innerHTML=months.map((m,i)=>`
    <div class="chart-col">
      <div class="chart-bars-pair">
        <div class="bar bar-navy" style="height:${(leads[i]/max)*100}px"></div>
        <div class="bar bar-gold" style="height:${(closed[i]/max)*100}px"></div>
      </div>
      <div class="chart-lbl">${m}</div>
    </div>
  `).join('');
}

