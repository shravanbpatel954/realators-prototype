function buildParticles(){
  const c = document.getElementById('particles');
  if(!c) return;
  for(let i=0;i<12;i++){
    const d = document.createElement('div');
    d.className = 'particle';
    const size = Math.random()*4+2;
    d.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;animation-duration:${Math.random()*15+10}s;animation-delay:${Math.random()*10}s;opacity:${Math.random()*.5+.2}`;
    c.appendChild(d);
  }
}

