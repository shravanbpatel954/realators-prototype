function openPropDetail(id){
  const p = props.find(x=>x.id===id);
  if(!p) return;
  document.getElementById('dPrice').textContent = p.price + ' ' + p.unit;
  document.getElementById('dName').textContent = p.name;
  document.getElementById('dLoc').textContent = '📍 ' + p.loc;
  document.getElementById('ds1').textContent = p.s1;
  document.getElementById('ds2').textContent = p.s2;
  document.getElementById('ds3').textContent = p.s3;
  document.getElementById('ds4').textContent = p.s4;
  document.getElementById('dDesc').textContent = p.desc;
  document.getElementById('dAmenities').innerHTML = p.amenities.map(a=>`<span class="am-tag">${a}</span>`).join('');
