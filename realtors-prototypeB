  document.getElementById('detailGalleryInner').innerHTML = `<button class="gallery-close" onclick="closeOverlay('propOverlay')">✕</button><div style="color:rgba(255,255,255,.5);text-align:center"><div style="font-size:4rem">${p.icon}</div><div style="margin-top:12px;font-size:.9rem">${p.name}</div></div>`;
  document.getElementById('dWaBtn').onclick = ()=>openWA(p.name+' — '+p.loc+' — '+p.price);
  openOverlay('propOverlay');
}

