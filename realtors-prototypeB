function openWA(info){
  const msg = `Hi! I saw *${info}* on *RealtorBazar* and I'm interested.\n\nPlease share more details. Thank you! 🙏`;
  window.open(`https://wa.me/${BROKER_NUM}?text=${encodeURIComponent(msg)}`,'_blank');
  toast('📱 Opening WhatsApp...');
}
function submitEnquiry(){
  const name=document.getElementById('fn').value||'Not provided';
  const phone=document.getElementById('fp').value||'Not provided';
  const email=document.getElementById('fe').value||'';
  const action=document.getElementById('fa').value;
  const type=document.getElementById('ft').value;
  const city=document.getElementById('fc').value;
  const budget=document.getElementById('fb').value;
  const msg=document.getElementById('fm').value||'';
  const waMsg=`*New Property Enquiry — RealtorBazar* 🏠\n\n👤 *Name:* ${name}\n📞 *Phone:* ${phone}${email?`\n📧 *Email:* ${email}`:''}\n\n🔍 *Looking To:* ${action}\n🏠 *Type:* ${type}\n📍 *City:* ${city}\n💰 *Budget:* ${budget}\n\n💬 *Message:* ${msg||'Not specified'}\n\n_Sent via RealtorBazar.com_`;
  window.open(`https://wa.me/${BROKER_NUM}?text=${encodeURIComponent(waMsg)}`,'_blank');
