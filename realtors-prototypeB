function setSearchTab(el){
  document.querySelectorAll('.s-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}
function setCat(el){
  document.querySelectorAll('.cat-pill').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const cat = el.textContent.replace(/[🏠🏢📐🔑⭐]/g,'').trim();
  if(cat==='All'){ buildPropsGrid(); return; }
  const type = cat==='Residential'?'Residential':cat==='Commercial'?'Commercial':cat==='Plots'?'Plot':cat==='Rental'?'Rental':cat==='Featured'?'Featured':'';
  const filtered = props.filter(p=>p.type===type || (type==='Featured'&&p.tag==='Featured'));
  const grid = document.getElementById('propsGrid');
  if(!filtered.length){ grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--text3)"><div style="font-size:3rem">🔍</div><div style="margin-top:12px;font-weight:600">No properties found</div><div style="margin-top:6px;font-size:.88rem">Try a different category</div></div>'; return; }
  grid.innerHTML = '';
  filtered.forEach(p=>{
    const tmp = document.createElement('div');
    tmp.innerHTML = document.getElementById('propsGrid').parentElement.innerHTML;
  });
  buildPropsGrid();
  setTimeout(()=>{
    const all = document.querySelectorAll('.prop-card');
    all.forEach(card=>{
      const locEl = card.querySelector('.prop-loc');
      const nameEl = card.querySelector('.prop-name');
      if(locEl&&nameEl){
        const propData = props.find(p=>p.name===nameEl.textContent);
        if(propData&&propData.type!==type&&!(type==='Featured'&&propData.tag==='Featured'))card.style.display='none';
      }
    });
  },0);
}

